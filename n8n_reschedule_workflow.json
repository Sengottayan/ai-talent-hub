        {
            "parameters": {
                "jsCode": "// Get original request data\nconst requestData = $('Extract Request Data').first().json;\nconst items = $input.all();\nconst requestedDate = new Date(requestData.requestedDate);\nconst endTime = new Date(requestedDate.getTime() + 60*60*1000);\n\n// Detailed Trace Log\nlet debugLog = [\"[Debug Trace]\"];\ndebugLog.push(`Req: ${requestedDate.toISOString()} - ${endTime.toISOString()}`);\ndebugLog.push(`Found ${items.length} items.`);\n\nconst hasConflict = items.some((item, index) => {\n    const ev = item.json;\n    if (!ev || ev.status === 'cancelled') {\n        debugLog.push(`#${index}: Cancelled/Empty`);\n        return false;\n    }\n    \n    const sStr = ev.start?.dateTime;\n    const eStr = ev.end?.dateTime;\n    \n    if (sStr && eStr) {\n        const evStart = new Date(sStr);\n        const evEnd = new Date(eStr);\n        \n        const cond1 = requestedDate < evEnd; // 04:00 < 05:00 (T)\n        const cond2 = endTime > evStart;     // 05:00 > 04:00 (T)\n        const isConflict = cond1 && cond2;\n        \n        debugLog.push(`#${index}: ${sStr} to ${eStr} | Conflict: ${isConflict} (S<E:${cond1}, E>S:${cond2})`);\n        return isConflict;\n    }\n    \n    debugLog.push(`#${index}: Missing Dates (S:${sStr}, E:${eStr})`);\n    return false;\n});\n\n// Append full debug log to description\nconst originalDesc = requestData.calendarDescription || ('Candidate: ' + requestData.candidateName + '\\nEmail: ' + requestData.candidateEmail + '\\nRole: ' + requestData.jobRole);\nconst finalDesc = originalDesc + \"\\n\\n\" + debugLog.join(\"\\n\");\n\nconst status = !hasConflict ? \"AVAILABLE\" : \"CONFLICT\";\n\nreturn { json: {\n  rescheduleId: requestData.rescheduleId,\n  interviewId: requestData.interviewId,\n  candidateEmail: requestData.candidateEmail,\n  candidateName: requestData.candidateName,\n  requestedDate: requestData.requestedDate,\n  jobRole: requestData.jobRole,\n  interviewLink: requestData.interviewLink,\n  calendarTitle: requestData.calendarTitle || ('Interview: ' + requestData.candidateName + ' – ' + requestData.jobRole),\n  calendarDescription: finalDesc,\n  isAvailable: !hasConflict,\n  availabilityStatus: status,\n  endTime: endTime.toISOString()\n} };"
            },
