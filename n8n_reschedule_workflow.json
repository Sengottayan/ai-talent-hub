        {
            "parameters": {
                "jsCode": "// Generate alternative available dates\nconst requestedDate = new Date($json.requestedDate);\nconst availableDates = [];\nconst webhookBaseUrl = \"https://n8n.bravecoast-7ddc0116.uaenorth.azurecontainerapps.io/webhook\";\nfor (let i = 1; i <= 7; i++) {\n  const alternateDate = new Date(requestedDate);\n  alternateDate.setDate(alternateDate.getDate() + i);\n  const morningSlot = new Date(alternateDate);\n  morningSlot.setHours(10, 0, 0, 0);\n  if (availableDates.length < 5) {\n    availableDates.push({ datetime: morningSlot.toISOString(), formatted: morningSlot.toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric', hour: '2-digit', minute: '2-digit' }), confirmLink: `${webhookBaseUrl}/confirm-date?rescheduleId=${$json.rescheduleId}&interviewId=${$json.interviewId}&date=${encodeURIComponent(morningSlot.toISOString())}&email=${encodeURIComponent($json.candidateEmail)}&name=${encodeURIComponent($json.candidateName)}&role=${encodeURIComponent($json.jobRole)}` });\n  }\n}\nreturn { json: { ...$json, availableDates } };"
